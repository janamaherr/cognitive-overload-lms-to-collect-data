@{
    ViewData["Title"] = "Memory Pattern Challenge";
}

<div class="d-flex flex-column align-items-center py-5" style="background:#f8f9fa;min-height:100vh;">
    <div class="card shadow-lg" style="max-width:800px;width:100%;border-radius:1rem;">
        <div class="card-body p-4">
            <h2 class="text-center mb-3" style="font-weight:600;letter-spacing:0.02em;">Memory Pattern Challenge</h2>
            <p class="text-center text-muted" style="font-size:0.9rem;">How to Play: Watch the sequence of highlighted squares carefully; when it ends, repeat the pattern by clicking the squares in order.</p>
            
            <div class="d-flex justify-content-between align-items-center my-3">
                <div><strong>Score:</strong> <span id="score">0</span></div>
                <div><strong>Time:</strong> <span id="timer">0</span>s</div>
            </div>

            <!-- Feedback Message -->
            <div id="feedbackMessage" class="alert" style="display: none;"></div>

            <div class="d-flex justify-content-center mt-3">
                <div id="gameBoard" class="memory-grid"></div>
            </div>

            <div class="text-center mt-4">
                <button id="startGameBtn" class="btn btn-success btn-lg">Start Game</button>
                <button id="playAgainBtn" class="btn btn-warning btn-lg" style="display: none;">Play Again</button>
                <button id="nextGameBtn" class="btn btn-info btn-lg" style="display: none;">Next Game →</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/behaviorLogger.js"></script>
    <script src="~/js/mouseSpeed.js"></script>
    <script>
        // Game state
        let gameState = {
            sessionId: sessionStorage.getItem('sessionId'),
            gameType: 'Memory Pattern Challenge',
            sectionNumber: 1,
            startTime: null,
            endTime: null,
            score: 0,
            level: 1,
            sequence: [],
            userSequence: [],
            gridSize: 4,
            showingSequence: false,
            gameStarted: false,
            gameCompleted: false,
            currentAttempts: 0,
            maxAttempts: 3 // Allow 3 attempts per game
        };
        
        // Initialize behavior tracking
        const behaviorLogger = new BehaviorLogger(gameState.sessionId, gameState.sectionNumber);
        const mouseTracker = new MouseSpeedTracker();
        
        // Timer
        let timerInterval;
        let seconds = 0;
        
        // Test API function
        document.getElementById('testApiBtn')?.addEventListener('click', async function() {
            const resultSpan = document.getElementById('apiTestResult');
            resultSpan.innerHTML = 'Testing...';
            
            try {
                const testResult = {
                    sessionId: sessionStorage.getItem('sessionId') || 'test-session',
                    gameType: 'Test',
                    sectionNumber: 0,
                    startTime: new Date().toISOString(),
                    endTime: new Date().toISOString(),
                    score: 0,
                    totalTimeSeconds: 0,
                    completed: true,
                    behaviorData: {
                        mouseMovements: [],
                        typingEvents: [],
                        headPositions: [],
                        hesitationPauses: [],
                        averageMouseSpeed: 0,
                        averageTypingSpeed: 0,
                        averageHeadMovement: 0
                    },
                    gameData: {}
                };
                
                const response = await fetch('/api/GameData/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(testResult)
                });
                
                const data = await response.json();
                
                if (data.success) {
                    resultSpan.innerHTML = '✅ API is working!';
                    resultSpan.style.color = 'green';
                } else {
                    resultSpan.innerHTML = `❌ Error: ${data.error}`;
                    resultSpan.style.color = 'red';
                }
            } catch (error) {
                resultSpan.innerHTML = `❌ Connection failed: ${error.message}`;
                resultSpan.style.color = 'red';
            }
        });
        
        // Start the game
        document.getElementById('startGameBtn').addEventListener('click', function() {
            startNewGame();
        });
        
        // Next game button
        document.getElementById('nextGameBtn').addEventListener('click', function() {
            window.location.href = '/Questions/Section2';
        });
        
        // Play again button
        document.getElementById('playAgainBtn').addEventListener('click', function() {
            resetAndPlayAgain();
        });
        
        function showFeedback(message, isSuccess) {
            const feedback = document.getElementById('feedbackMessage');
            feedback.textContent = message;
            feedback.className = isSuccess ? 'alert alert-success' : 'alert alert-danger';
            feedback.style.display = 'block';
            
            // Hide after 2 seconds
            setTimeout(() => {
                feedback.style.display = 'none';
            }, 2000);
        }
        
        function startNewGame() {
            gameState.startTime = new Date().toISOString();
            gameState.gameStarted = true;
            gameState.gameCompleted = false;
            gameState.score = 0;
            gameState.currentAttempts = 0;
            seconds = 0;
            
            document.getElementById('score').textContent = gameState.score;
            document.getElementById('startGameBtn').style.display = 'none';
            document.getElementById('nextGameBtn').style.display = 'none';
            document.getElementById('playAgainBtn').style.display = 'none';
            
            startTimer();
            generateGrid();
            startLevel();
            
            // Start tracking behavior
            mouseTracker.startTracking();
            behaviorLogger.startGame(gameState.gameType);
            
            console.log('Game started at:', gameState.startTime);
        }
        
        function resetAndPlayAgain() {
            // Save current game data first
            saveGameData(false).then(() => {
                // Reset for new game
                startNewGame();
            });
        }
        
        function startTimer() {
            if (timerInterval) clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                seconds++;
                document.getElementById('timer').textContent = seconds;
            }, 1000);
        }
        
        function generateGrid() {
            const board = document.getElementById('gameBoard');
            board.innerHTML = '';
            board.style.gridTemplateColumns = `repeat(${gameState.gridSize}, 1fr)`;
            
            for (let i = 0; i < gameState.gridSize * gameState.gridSize; i++) {
                const cell = document.createElement('div');
                cell.className = 'memory-cell';
                cell.dataset.index = i;
                cell.addEventListener('click', handleCellClick);
                board.appendChild(cell);
            }
        }
        
        function startLevel() {
            // Generate sequence - make it a bit challenging but doable
            const sequenceLength = 5; // Fixed length for simplicity
            gameState.sequence = [];
            gameState.userSequence = [];
            gameState.currentAttempts++;
            
            for (let i = 0; i < sequenceLength; i++) {
                gameState.sequence.push(Math.floor(Math.random() * (gameState.gridSize * gameState.gridSize)));
            }
            
            console.log('Sequence to remember:', gameState.sequence);
            showSequence();
        }
        
        function showSequence() {
            gameState.showingSequence = true;
            
            // Disable clicks during sequence display
            document.querySelectorAll('.memory-cell').forEach(cell => {
                cell.style.pointerEvents = 'none';
            });
            
            // Show "Watch carefully" message
            showFeedback('Watch the sequence carefully!', true);
            
            // Highlight each cell in sequence
            gameState.sequence.forEach((cellIndex, i) => {
                setTimeout(() => {
                    const cell = document.querySelector(`[data-index="${cellIndex}"]`);
                    if (cell) {
                        cell.classList.add('active');
                        
                        setTimeout(() => {
                            cell.classList.remove('active');
                            
                            // Enable clicks after sequence ends
                            if (i === gameState.sequence.length - 1) {
                                setTimeout(() => {
                                    gameState.showingSequence = false;
                                    document.querySelectorAll('.memory-cell').forEach(cell => {
                                        cell.style.pointerEvents = 'auto';
                                    });
                                    showFeedback('Your turn! Click the squares in the same order.', true);
                                }, 500);
                            }
                        }, 500);
                    }
                }, i * 800); // 800ms between each highlight
            });
        }
        
        function handleCellClick(e) {
            if (gameState.showingSequence || !gameState.gameStarted || gameState.gameCompleted) return;
            
            const cellIndex = parseInt(e.target.dataset.index);
            const currentPosition = gameState.userSequence.length;
            
            // Visual feedback
            e.target.classList.add('clicked');
            setTimeout(() => {
                e.target.classList.remove('clicked');
            }, 200);
            
            // Check if this click matches the expected sequence
            if (cellIndex === gameState.sequence[currentPosition]) {
                // Correct click
                gameState.userSequence.push(cellIndex);
                e.target.classList.add('correct-click');
                setTimeout(() => {
                    e.target.classList.remove('correct-click');
                }, 300);
                
                // Check if sequence is complete
                if (gameState.userSequence.length === gameState.sequence.length) {
                    // Completed the sequence correctly!
                    gameState.score += 10;
                    document.getElementById('score').textContent = gameState.score;
                    
                    showFeedback('🎉 Perfect! You remembered the sequence!', true);
                    gameState.gameCompleted = true;
                    
                    // Disable further clicks
                    document.querySelectorAll('.memory-cell').forEach(cell => {
                        cell.style.pointerEvents = 'none';
                    });
                    
                    // Show next game options
                    clearInterval(timerInterval);
                    document.getElementById('nextGameBtn').style.display = 'inline-block';
                    document.getElementById('playAgainBtn').style.display = 'inline-block';
                    
                    // Save the successful game data
                    saveGameData(true);
                }
            } else {
                // Wrong click - show error
                e.target.classList.add('wrong-click');
                setTimeout(() => {
                    e.target.classList.remove('wrong-click');
                }, 300);
                
                showFeedback('❌ Hard Luck! Wrong sequence!', false);
                
                // Show what they clicked vs what was expected
                console.log('Wrong! Expected:', gameState.sequence[currentPosition], 'Got:', cellIndex);
                
                // Game over for this attempt
                gameState.gameCompleted = true;
                
                // Disable further clicks
                document.querySelectorAll('.memory-cell').forEach(cell => {
                    cell.style.pointerEvents = 'none';
                });
                
                clearInterval(timerInterval);
                
                // Show both play again and next game buttons
                document.getElementById('playAgainBtn').style.display = 'inline-block';
                document.getElementById('nextGameBtn').style.display = 'inline-block';
            }
            
            // Log behavior data
            behaviorLogger.logMouseClick(cellIndex);
        }
        
        async function saveGameData(completed) {
            // Stop tracking
            mouseTracker.stopTracking();
            const mouseData = mouseTracker.getData();
            
            // Collect behavior data
            const behaviorData = behaviorLogger.endGame();
            
            // Fix: Ensure all dates in hesitationPauses are proper ISO strings and filter out incomplete pauses
            if (behaviorData.hesitationPauses) {
                behaviorData.hesitationPauses = behaviorData.hesitationPauses
                    .filter(pause => pause.endTime != null) // Only include completed pauses
                    .map(pause => ({
                        ...pause,
                        startTime: pause.startTime ? new Date(pause.startTime).toISOString() : null,
                        endTime: pause.endTime ? new Date(pause.endTime).toISOString() : null
                    }));
            }
            
            console.log("Ending game...");
            console.log("Game State:", gameState);
            
            // Prepare game result
            const gameResult = {
                sessionId: gameState.sessionId,
                gameType: gameState.gameType,
                sectionNumber: gameState.sectionNumber,
                startTime: gameState.startTime,
                endTime: new Date().toISOString(),
                score: gameState.score,
                totalTimeSeconds: seconds,
                completed: completed,
                behaviorData: {
                    mouseMovements: mouseData.movements || [],
                    typingEvents: behaviorData.typingEvents || [],
                    headPositions: behaviorData.headPositions || [],
                    hesitationPauses: behaviorData.hesitationPauses || [],
                    averageMouseSpeed: mouseData.averageSpeed || 0,
                    averageTypingSpeed: 0,
                    averageHeadMovement: 0
                },
                gameData: {
                    gridSize: gameState.gridSize,
                    sequenceShown: gameState.sequence,
                    sequenceClicked: gameState.userSequence,
                    correctClicks: gameState.userSequence.filter((val, idx) => val === gameState.sequence[idx]).length,
                    totalAttempts: gameState.currentAttempts
                }
            };
            
            console.log("Sending game result:", gameResult);
            
            // Save to MongoDB
            try {
                const response = await fetch('/api/GameData/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(gameResult)
                });
                
                const data = await response.json();
                console.log("Server response:", data);
                
                if (data.success) {
                    console.log("Game data saved successfully!");
                } else {
                    console.error("Failed to save:", data.error);
                }
            } catch (error) {
                console.error('Error saving game data:', error);
            }
        }
    </script>
}

<style>
    .memory-grid {
        display: grid;
        gap: 5px;
        width: 400px;
        height: 400px;
        margin: 0 auto;
    }
    
    .memory-cell {
        background-color: #f0f0f0;
        border: 2px solid #ccc;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .memory-cell.active {
        background-color: #ff6b6b;
        transform: scale(0.95);
    }
    
    .memory-cell.clicked {
        background-color: #4ecdc4;
    }
    
    .memory-cell.correct-click {
        background-color: #4CAF50;
        transform: scale(0.95);
    }
    
    .memory-cell.wrong-click {
        background-color: #f44336;
        transform: scale(0.95);
    }
    
    .memory-cell:hover {
        background-color: #e0e0e0;
    }
    
    #feedbackMessage {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
        min-width: 300px;
        text-align: center;
    }
</style>