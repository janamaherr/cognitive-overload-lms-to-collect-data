@{
    ViewData["Title"] = "Cognitive Overload LMS";
}

<div class="text-center">
    <h1 class="display-4">Cognitive Overload Assessment</h1>
    
    <div class="row mt-5">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Start Your Assessment</h5>
                    
                    <div class="form-group mb-3">
                        <label for="userName">Enter Your Name/ID:</label>
                        <input type="text" class="form-control" id="userName" 
                               placeholder="Enter name or ID" required>
                    </div>
                    
                    <button id="startBtn" class="btn btn-primary">Begin Assessment</button>
                </div>
            </div>
            
            <div class="mt-4">
                <h5>You will complete 3 sections:</h5>
                <ul class="list-group">
                    <li class="list-group-item">Section 1: Memory Pattern Challenge</li>
                    <li class="list-group-item">Section 2: Word Scramble Race</li>
                    <li class="list-group-item">Section 3: Rotating Circle Arrow Challenge</li>
                </ul>
                <p class="mt-3 text-muted">Each section is timed. Try to complete each game as quickly and accurately as possible.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('startBtn').addEventListener('click', async function() {
            const userName = document.getElementById('userName').value;
            
            if (!userName) {
                alert('Please enter your name or ID');
                return;
            }
            
            try {
                const response = await fetch('/Home/StartSession', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(userName)
                });
                
                const data = await response.json();
                
                // Store sessionId in sessionStorage for later use
                sessionStorage.setItem('sessionId', data.sessionId);
                sessionStorage.setItem('userName', userName);
                
                // Redirect to first section
                window.location.href = '/Questions/Section1';
            } catch (error) {
                console.error('Error starting session:', error);
                alert('Error starting session. Please try again.');
            }
        });
    </script>
}