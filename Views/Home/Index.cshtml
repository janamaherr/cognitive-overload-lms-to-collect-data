@{
    ViewData["Title"] = "Cognitive Overload LMS";
}

<div class="d-flex vh-100 align-items-center justify-content-center bg-light">
    <div class="card shadow-lg w-75" style="max-width: 700px; border-radius: 1rem;">
        <div class="card-body p-5">
            <h1 class="display-5 text-center mb-4" style="font-weight: 600; letter-spacing: 0.05em;">Cognitive Overload Assessment</h1>

            <div class="mb-4">
                <h5 class="card-title" style="font-weight: 500;">Begin Assessment</h5>
                <div class="form-group mb-3">
                    <label for="userName" class="form-label">Name or ID</label>
                    <input type="text" class="form-control" id="userName" 
                           placeholder="Enter your name" required>
                </div>
                <button id="startBtn" class="btn btn-primary btn-lg w-100">Start</button>
            </div>

            <hr />

            <div>
                <h6 class="mb-2" style="font-weight: 500;">Sections</h6>
                <ul class="list-group mb-3">
                    <li class="list-group-item">Section 1: Memory Pattern Challenge</li>
                    <li class="list-group-item">Section 2: Word Scramble Race</li>
                    <li class="list-group-item">Section 3: Twisty Arrow Game</li>
                </ul>
                <p class="text-muted small">Each section is timed; complete as quickly and accurately as possible.</p>
                <p class="text-muted small">All data will be recorded for research purposes.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('startBtn').addEventListener('click', async function() {
            const userName = document.getElementById('userName').value;
            
            if (!userName) {
                alert('Please enter your name or ID');
                return;
            }
            
            try {
                const response = await fetch('/Home/StartSession', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(userName)
                });
                
                const data = await response.json();
                
                // Store sessionId in sessionStorage for later use
                sessionStorage.setItem('sessionId', data.sessionId);
                sessionStorage.setItem('userName', userName);
                
                // Redirect to first section
                window.location.href = '/Questions/Section1';
            } catch (error) {
                console.error('Error starting session:', error);
                alert('Error starting session. Please try again.');
            }
        });
    </script>
}